# ── Cloud Server (trading_server.py) ──────────

# Cloudflare R2 credentials
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# API key that clients must send in the x-api-key header
SERVER_API_KEY=replace_with_a_strong_random_key

# ── Bridge (bridge.py) ────────────────────────

# Must match SERVER_API_KEY above
MCP_API_KEY=replace_with_a_strong_random_key

# URL of the deployed Cloud Run service
MCP_SERVER_URL=https://your-service-name.run.app

# Directory where bridge_debug_log.txt will be written (defaults to script folder)
# LOG_DIR=C:\Users\you\Desktop\Work\MCP

# ── Local Server (trading_server_local.py) ────

# Absolute or relative path to the folder containing .parquet files
DATA_DIR=./TestData
